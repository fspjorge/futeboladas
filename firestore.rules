rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /jogos/{id} {
      // Leitura apenas para autenticados
      allow read: if request.auth != null;

      // Criar jogo: autenticado + campos válidos
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['ativo','titulo','local','jogadores','data','lat','lon','createdBy','createdAt','createdByName','createdByPhoto'])
        && request.resource.data.ativo is bool
        && request.resource.data.local is string
        && request.resource.data.jogadores is int
        && request.resource.data.data is timestamp
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && (
          !(request.resource.data.keys().hasAny(['lat','lon']))
          || (request.resource.data.lat is float && request.resource.data.lon is float)
        );

      // Editar jogo: apenas o criador, sem alterar o createdBy
      allow update: if request.auth != null
        && resource.data.createdBy == request.auth.uid
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.keys().hasOnly(['ativo','titulo','local','jogadores','data','lat','lon','createdBy','createdAt','createdByName','createdByPhoto'])
        && request.resource.data.local is string
        && request.resource.data.jogadores is int
        && request.resource.data.data is timestamp
        && (
          !(request.resource.data.keys().hasAny(['lat','lon']))
          || (request.resource.data.lat is float && request.resource.data.lon is float)
        );

      // Apagar jogo: apenas o criador
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      // Subcoleção de presenças
      match /presencas/{uid} {
        allow read: if request.auth != null;
        // Cada utilizador gere a sua própria presença
        allow create, update: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.keys().hasOnly(['vai','updatedAt','name','photo'])
          && request.resource.data.vai is bool;
        // O utilizador pode apagar a sua, ou o dono do jogo pode apagar todas
        allow delete: if request.auth != null
          && (request.auth.uid == uid || get(/databases/$(database)/documents/jogos/$(id)).data.createdBy == request.auth.uid);
      }

      // Subcoleção admin: apenas o criador do jogo
      match /admin/{doc} {
        allow read: if request.auth != null
          && get(/databases/$(database)/documents/jogos/$(id)).data.createdBy == request.auth.uid;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/jogos/$(id)).data.createdBy == request.auth.uid;
      }
    }
  }
}
